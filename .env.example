# Variables de entorno para EduSuite
# Copia este archivo a .env y completa con tus valores

# Token de GitHub para operaciones con la API
GITHUB_TOKEN=

# Configuración de la base de datos
DB_PATH=school.db

# Configuración de la aplicación
APP_NAME=EduSuite
APP_VERSION=1.0.0

# Configuración de logging
LOG_LEVEL=INFO

# NOTA: Para usar el token de GitHub en operaciones git,
# configura tu git para usar el token:
# git config --global credential.helper store
# o usa: https://TOKEN@github.com/usuario/repo.git